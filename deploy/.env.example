# 本地开发环境变量模板
# 使用方法：复制为 config/local.env 并修改实际值（local.env 已被 git 忽略）
# 启动时通过 .vscode/launch.json 中的 envFile 加载（复制 launch.json.example 为 launch.json）
# 注意：注释请单独成行，不要在值后面写 # 注释（可能被当成密码的一部分）

# ========== MySQL（Nacos + 业务服务共用连接信息） ==========
# 不要设置 MYSQL_DB：edms-register 默认连 edms_config，业务服务默认连 edms
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
# edms-register 用（application.properties 读取 MYSQL_PASSWORD）
MYSQL_PASSWORD=root
# upms/codegen/quartz 用（Nacos 配置读取 MYSQL_PWD）
MYSQL_PWD=root

# ========== Redis（覆盖 Nacos application-dev.yml 里的 edms-redis） ==========
SPRING_DATA_REDIS_HOST=127.0.0.1
# 非默认端口时取消注释
# SPRING_DATA_REDIS_PORT=6379

# ========== 各业务服务连接 Nacos ==========
NACOS_HOST=127.0.0.1
NACOS_PORT=8848
SPRING_CLOUD_NACOS_USERNAME=nacos
SPRING_CLOUD_NACOS_PASSWORD=nacos

# Spring 激活 dev 配置
SPRING_PROFILES_ACTIVE=dev
